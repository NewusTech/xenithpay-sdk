  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "function generateRandomString(length) {",
          "    const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';",
          "    let result = '';",
          "    for (let i = 0; i < length; i++) {",
          "        result += characters.charAt(Math.floor(Math.random() * characters.length));",
          "    }",
          "    return result;",
          "}",
          "",
          "const randomString = generateRandomString(100);",
          "pm.environment.set('idempotencyKey', randomString);",
          "",
          "// VERSION 2",
          "",
          "/*",
          " * Pre-request script for generating signature payload with minified JSON body.",
          " */",
          "",
          "",
          "// Get the current timestamp in RFC3339 format",
          "const timestamp = new Date().toISOString();",
          "console.log(\"timestamp:\", timestamp);",
          "",
          "// Get the request method and URI",
          "const method = pm.request.method;",
          "console.log(\"method:\", method);",
          "const uri = pm.request.url.getPathWithQuery();",
          "console.log(\"uri:\", uri);",
          "",
          "// Initialize minifiedBody as an empty string",
          "let minifiedBody = \"\";",
          "",
          "// Check if request body exists and is not empty",
          "if (pm.request.body && pm.request.body.raw) {",
          "    try {",
          "        // Attempt to parse and minify the JSON body",
          "        const parsedBody = JSON.parse(pm.request.body.raw);",
          "        minifiedBody = JSON.stringify(parsedBody);",
          "    } catch (error) {",
          "        // If the body is not valid JSON, log an error and use the raw body",
          "        console.error(\"Error parsing JSON body. Using raw body instead.\");",
          "        minifiedBody = pm.request.body.raw;",
          "    }",
          "}",
          "",
          "console.log(\"minifiedBody:\", minifiedBody);",
          "",
          "// Concatenate method, URI, timestamp, and minified body to form the signature payload",
          "const signaturePayload = method + \"\\n\" + uri + \"\\n\" + timestamp + \"\\n\" + minifiedBody;",
          "console.log(\"signaturePayload:\", signaturePayload);",
          "",
          "// Retrieve the secret key from the environment",
          "const secretKey = pm.environment.get(\"secret_key\");",
          "console.log(\"Secret key:\", secretKey);",
          "",
          "// Create a HMAC SHA256 hash of the signature payload using the secret key",
          "const hash = CryptoJS.HmacSHA256(signaturePayload, secretKey);",
          "",
          "// Encode the hash in base64 format",
          "const signature = CryptoJS.enc.Base64.stringify(hash);",
          "console.log(\"signature:\", signature);",
          "",
